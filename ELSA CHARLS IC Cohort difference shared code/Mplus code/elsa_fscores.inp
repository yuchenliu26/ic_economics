TITLE:

    ELSA
    Bifactor model
    All waves
    Partial information
    WLSMV
    Factor scores
    
DATA:

    FILE = "C:\Users\DELL\Documents\Mplus\elsa_for_fscores.csv";
    
VARIABLE:

    NAMES =         ID wave 
                    depres effort sleep happy lonely going
                    wspeed chr5sec balance
                    grip fev hba
                    imrc dlrc series memory
                    hearing nsight dsight
                    bal_bin;
                    
    USEVARIABLE =   depres effort sleep happy lonely going
                    wspeed chr5sec bal_bin
                    grip fev hba
                    imrc dlrc memory
                    hearing nsight dsight;

    CATEGORICAL =   depres effort sleep happy lonely going
                    bal_bin memory hearing nsight dsight;

    MISSING = ALL (-9999); 

    CLUSTER = ID;


ANALYSIS:

    TYPE = COMPLEX;
    ESTIMATOR = WLSMV;
    

MODEL:

    g BY            depres* effort sleep happy lonely going
                    wspeed chr5sec bal_bin
                    grip fev hba
                    imrc dlrc memory
                    hearing nsight dsight;

    psych BY        depres* effort sleep happy lonely going;

    vital BY        grip* fev hba;

    cogni BY        imrc* dlrc memory;

    sensor BY       hearing* nsight dsight;

    g@1;
    psych@1;
    vital@1;
    cogni@1;
    sensor@1;

    [g@0];
    [psych@0];
    [vital@0];
    [cogni@0];
    [sensor@0];

    g       WITH psych@0 vital@0 cogni@0 sensor@0;
    psych   WITH vital@0 cogni@0 sensor@0;
    vital   WITH cogni@0 sensor@0;
    cogni   WITH sensor@0;

    {depres@1};
    {effort@1};
    {sleep@1};
    {happy@1};
    {lonely@1};
    {going@1};
    {bal_bin@1};
    {memory@1};
    {hearing@1};
    {nsight@1};
    {dsight@1};

    wspeed WITH chr5sec;


OUTPUT:

    TECH1 STANDARDIZED(STDYX);


SAVEDATA:

    FILE = elsa_fscores.csv;
    SAVE = FSCORES;